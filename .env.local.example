# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings -> API). Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Agentify — Microsoft Teams/Outlook integration (plan-agentic.md)
# AGENT_TOKEN_ENCRYPTION_KEY: 32 random bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# From your Azure AD app registration (portal.azure.com -> App registrations):
AGENT_TOKEN_ENCRYPTION_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/integrations/microsoft/callback

# Backend-only, trusted, bypasses RLS entirely — from Supabase Project
# Settings -> API -> "service_role" secret key. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the cron scheduler must send to /api/cron/poll-meetings.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
